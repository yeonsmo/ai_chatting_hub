# Database (n8n과 공유 PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=claude_chat

# JWT 보안 키 (반드시 변경하세요)
SECRET_KEY=change_me_to_a_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# IP 화이트리스트 (쉼표로 구분, CIDR 표기 가능)
ALLOWED_IPS=192.168.0.0/24,127.0.0.1

# Claude API 키 (관리자 패널에서도 추가 가능)
ANTHROPIC_API_KEY=

# 가비아 AI Hub API 키 (GPT/DeepSeek/Gemini 등)
GABIA_API_KEY=
AI_HUB_BASE_URL=https://ai-hub.gabia.com

# Superadmin 설정
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_INITIAL_PASSWORD=change_me
