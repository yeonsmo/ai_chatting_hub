# Database (n8n과 공유 PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=claude_chat

# JWT 보안 키 (반드시 변경하세요 — 16자 미만이면 서버가 기동을 거부합니다)
SECRET_KEY=change_me_to_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# IP 화이트리스트 (쉼표로 구분, CIDR 표기 가능)
ALLOWED_IPS=192.168.0.0/24,127.0.0.1

# X-Forwarded-For를 신뢰할 프록시 IP (Nginx 등 리버스 프록시가 접속해 오는 주소)
# 여기 속한 IP에서 온 요청만 XFF 헤더를 클라이언트 IP로 인정합니다.
# ⚠ 반드시 실제 프록시 주소로 최소화하세요. 이 대역이 ALLOWED_IPS를 포함하면
#    XFF 위조로 IP 화이트리스트가 우회될 수 있습니다. (기본: 루프백만 신뢰)
TRUSTED_PROXIES=127.0.0.1,::1

# Claude API 키 (관리자 패널에서도 추가 가능 — provider: anthropic)
ANTHROPIC_API_KEY=

# 가비아 AI Hub API 키 (GPT/DeepSeek/Gemini 등 — 관리자 패널 provider: gabia)
GABIA_API_KEY=
AI_HUB_BASE_URL=https://ai-hub.gabia.com

# Azure OpenAI / AWS Bedrock / OpenAI 공식 / Gemini 키는
# 관리자 패널 > API 키 탭에서 등록합니다 (azure: endpoint·api_version,
# bedrock: aws_secret_key·region 추가 설정 필요).
# 모델별 호출처는 관리자 패널 > 모델 라우팅 탭에서 지정합니다.

# Superadmin 설정 (비워두면 계정을 만들지 않습니다)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_INITIAL_PASSWORD=change_me

# 파일 업로드
UPLOAD_DIR=data/uploads
MAX_UPLOAD_MB=50

# 스킬 연동 SSRF 예외: 신뢰하는 사내 호스트/대역만 사설 IP여도 허용 (콤마 구분, *.도메인/CIDR 지원)
SKILL_INTERNAL_ALLOWED_HOSTS=*.hpengineeringwork.com

# DLP(유출방지): 나가는 내용의 민감정보 마스킹. 카테고리: rrn,card,account,bizno,phone,email
# DLP_MODEL_EGRESS=true 로 켜면 AI 모델(가비아 등)로 보내는 대화도 마스킹됨.
#   주의: 그 번호가 들어가는 서식 자동작성 결과도 마스킹되니, 서식에 쓰는 카테고리는 빼거나 off 유지.
DLP_MODEL_EGRESS=false
# 외부 API로 보내는 스킬 파라미터 마스킹(서식과 무관, 권장 on).
#   '회사(사내) 도메인'으로 나가는 값은 마스킹하지 않는다(아래 DLP_COMPANY_HOSTS 기준).
DLP_SKILL_EGRESS=true
DLP_CATEGORIES=rrn,card,account,bizno,phone
# 마스킹을 면제할 사내 도메인. 비우면 SKILL_INTERNAL_ALLOWED_HOSTS를 그대로 재사용.
#   SSRF 허용목록과 DLP 면제 대상을 다르게 두고 싶을 때만 채운다(콤마, *.도메인/정확호스트).
DLP_COMPANY_HOSTS=

# HR 모듈 연동(직원 명부 동기화). 비우면 비활성.
HR_BASE_URL=
HR_API_KEY=
# 키를 실을 헤더/접두. 기본은 Authorization: Bearer <키>. X-API-Key 방식이면 헤더=X-API-Key, 접두="" 로.
HR_AUTH_HEADER=Authorization
HR_AUTH_PREFIX=Bearer
HR_EMPLOYEES_PATH=/api/v1/employees
HR_DOCUMENTS_PATH=/api/v1/documents/ingest
# 기안 서류의 결재 상태 조회 경로(폴링). {ref} 자리에 HR 문서 식별자 치환. 비우면 폴링 안 함(콜백만).
#   예: /api/v1/documents/{ref}  → 3분마다 승인/반려 확인 후 사용자에게 팝업 알림
HR_DOCUMENT_STATUS_PATH=
# HR → 허브 승인/반려 콜백(push) 인증 토큰. 설정 시 HR이 POST /api/documents/hr-callback 으로
#   {document_id, status: approved|rejected, note?} 전송(헤더 X-HR-Callback-Token). 비우면 콜백 비활성.
HR_CALLBACK_TOKEN=
# HR에만 있는 직원 계정 자동 생성(true/false). 생성 시 임시비번 발급 + 최초 로그인 시 변경 강제.
HR_AUTO_CREATE=false
HR_DEFAULT_ROLE=user
# 직급/직위 → 역할 매핑(JSON). 예: {"부장":"manager","이사":"admin"}
HR_ROLE_MAP={}

# SSO(하이웍스 등 OAuth2 로그인) — 진짜 본인인증. 비우면 비활성.
# 하이웍스 관리자/개발자센터에서 앱 등록 후 값 입력. 리다이렉트 URI를 아래와 동일하게 등록할 것.
SSO_ENABLED=false
SSO_LABEL=하이웍스
SSO_AUTHORIZE_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=https://<허브주소>/api/auth/sso/callback
SSO_SCOPE=
# 하이웍스 사용자정보 응답의 키 이름(실제 응답에 맞게)
SSO_USERINFO_EMAIL_FIELD=email
SSO_USERINFO_EMPNO_FIELD=employee_no
SSO_USERINFO_NAME_FIELD=name
# 미등록 계정 자동 생성(사내 전원 허용 시 true). 기본은 사전 등록/HR 동기화 계정만 허용.
SSO_AUTO_CREATE=false
SSO_DEFAULT_ROLE=user
